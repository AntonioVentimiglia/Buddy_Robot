<?xml version="1.0" ?>
<sdf version="1.9">
  <model name="buddy_v0_1">
    <pose>0 0 0 0 0 0</pose>
    <self_collide>false</self_collide>

    <link name="base_link">
      <pose>0 0 0.10 0 0 0</pose>
      <inertial>
        <mass>20.0</mass>
        <inertia><ixx>0.20</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.20</iyy><iyz>0</iyz><izz>0.25</izz></inertia>
      </inertial>
      <collision name="collision"><geometry><box><size>0.28 0.22 0.10</size></box></geometry></collision>
      <visual name="visual"><geometry><box><size>0.28 0.22 0.10</size></box></geometry></visual>
    </link>

    <link name="left_front_wheel_link">
      <pose>0.09 0.13 0.06 0 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia></inertial>
      <collision name="collision"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></collision>
      <visual name="visual"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></visual>
    </link>
    <joint name="left_front_wheel_joint" type="revolute">
      <parent>base_link</parent><child>left_front_wheel_link</child><axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="left_rear_wheel_link">
      <pose>-0.09 0.13 0.06 0 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia></inertial>
      <collision name="collision"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></collision>
      <visual name="visual"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></visual>
    </link>
    <joint name="left_rear_wheel_joint" type="revolute">
      <parent>base_link</parent><child>left_rear_wheel_link</child><axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="right_front_wheel_link">
      <pose>0.09 -0.13 0.06 0 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia></inertial>
      <collision name="collision"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></collision>
      <visual name="visual"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></visual>
    </link>
    <joint name="right_front_wheel_joint" type="revolute">
      <parent>base_link</parent><child>right_front_wheel_link</child><axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="right_rear_wheel_link">
      <pose>-0.09 -0.13 0.06 0 0 0</pose>
      <inertial><mass>0.5</mass><inertia><ixx>0.001</ixx><ixy>0</ixy><ixz>0</ixz><iyy>0.001</iyy><iyz>0</iyz><izz>0.001</izz></inertia></inertial>
      <collision name="collision"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></collision>
      <visual name="visual"><pose>0 0 0 1.57079632679 0 0</pose><geometry><cylinder><radius>0.06</radius><length>0.035</length></cylinder></geometry></visual>
    </link>
    <joint name="right_rear_wheel_joint" type="revolute">
      <parent>base_link</parent><child>right_rear_wheel_link</child><axis><xyz>0 1 0</xyz><limit><lower>-1e16</lower><upper>1e16</upper></limit></axis>
    </joint>

    <link name="base_laser">
      <pose>0.06 0 0.20 0 0 0</pose>
      <sensor name="scan" type="gpu_lidar">
        <topic>/scan</topic>
        <update_rate>10</update_rate>
        <lidar>
          <scan><horizontal><samples>360</samples><resolution>1</resolution><min_angle>-3.14159</min_angle><max_angle>3.14159</max_angle></horizontal></scan>
          <range><min>0.08</min><max>8.0</max><resolution>0.01</resolution></range>
        </lidar>
        <always_on>true</always_on>
        <visualize>true</visualize>
      </sensor>
      <visual name="visual"><geometry><cylinder><radius>0.035</radius><length>0.035</length></cylinder></geometry></visual>
    </link>
    <joint name="base_laser_joint" type="fixed"><parent>base_link</parent><child>base_laser</child></joint>

    <link name="front_camera_link">
      <pose>0.15 0 0.16 0 0 0</pose>
      <visual name="visual"><geometry><box><size>0.07 0.025 0.025</size></box></geometry></visual>
    </link>
    <joint name="front_camera_joint" type="fixed"><parent>base_link</parent><child>front_camera_link</child></joint>

    <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
      <left_joint>left_front_wheel_joint</left_joint>
      <left_joint>left_rear_wheel_joint</left_joint>
      <right_joint>right_front_wheel_joint</right_joint>
      <right_joint>right_rear_wheel_joint</right_joint>
      <wheel_separation>0.26</wheel_separation>
      <wheel_radius>0.06</wheel_radius>
      <odom_publish_frequency>50</odom_publish_frequency>
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
    </plugin>
  </model>
</sdf>
